---
import QRCode from 'qrcode';

const SITE = 'https://taymoorfouladi.pages.dev';

const qrSvgRaw = await QRCode.toString(SITE, {
  type: 'svg',
  errorCorrectionLevel: 'M',
  margin: 0,
  color: { dark: '#1a1a1a', light: '#0000' },
});

const qrSvg = qrSvgRaw
  .replace(/\swidth="[^"]*"/, '')
  .replace(/\sheight="[^"]*"/, '');
---

<div class="bc-wrapper">
  <div class="bc-card" id="bc-card" role="button" tabindex="0" aria-label="Business card — click or tap to flip">
    <div class="bc-face bc-front">
      <div class="bc-content">
        <p class="bc-eyebrow">Director</p>
        <h3 class="bc-name">
          <span>Taymoor</span>
          <span>Fouladi</span>
        </h3>
        <p class="bc-role">
          AI Transformation<br/>
          Digital Product<br/>
          Customer Experience
        </p>
        <p class="bc-loc">Tokyo · Japan</p>
      </div>
      <div class="bc-decor" aria-hidden="true">
        <div class="bc-circle"></div>
        <div class="bc-ring bc-ring-1"></div>
        <div class="bc-ring bc-ring-2"></div>
        <div class="bc-dot"></div>
      </div>
      <div class="bc-flip-hint" aria-hidden="true">Tap to flip ↻</div>
    </div>

    <div class="bc-face bc-back">
      <div class="bc-back-grid">
        <div class="bc-qr-block">
          <div class="bc-qr" set:html={qrSvg}></div>
          <p class="bc-qr-label">Scan me</p>
        </div>
        <div class="bc-back-info">
          <p class="bc-eyebrow">Connect</p>
          <ul class="bc-links">
            <li>
              <span class="bc-link-label">Web</span>
              <span class="bc-link-val">taymoorfouladi.pages.dev</span>
            </li>
            <li>
              <span class="bc-link-label">LinkedIn</span>
              <span class="bc-link-val">/in/taymoor-fouladi</span>
            </li>
            <li>
              <span class="bc-link-label">Based in</span>
              <span class="bc-link-val">Tokyo, Japan</span>
            </li>
          </ul>
          <p class="bc-back-meta">20+ years · Rakuten · adidas · Esprit · Harrods · YNAP</p>
        </div>
      </div>
      <div class="bc-flip-hint" aria-hidden="true">↻ Flip back</div>
    </div>
  </div>

  <div class="bc-actions">
    <a
      href="/taymoor-fouladi.vcf"
      download="Taymoor-Fouladi.vcf"
      class="bc-btn bc-btn-primary"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      Save to contacts
    </a>
    <button type="button" id="bc-flip-btn" class="bc-btn bc-btn-ghost">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="1 4 1 10 7 10"></polyline>
        <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
      </svg>
      Flip card
    </button>
    <button type="button" id="bc-share-btn" class="bc-btn bc-btn-ghost">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="18" cy="5" r="3"></circle>
        <circle cx="6" cy="12" r="3"></circle>
        <circle cx="18" cy="19" r="3"></circle>
        <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
        <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
      </svg>
      <span id="bc-share-label">Share link</span>
    </button>
  </div>
</div>

<script>
  const card = document.getElementById('bc-card');
  const flipBtn = document.getElementById('bc-flip-btn');
  const shareBtn = document.getElementById('bc-share-btn');
  const shareLabel = document.getElementById('bc-share-label');

  function toggleFlip() {
    card?.classList.toggle('is-flipped');
  }

  card?.addEventListener('click', toggleFlip);
  card?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      toggleFlip();
    }
  });
  flipBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleFlip();
  });

  shareBtn?.addEventListener('click', async () => {
    const url = 'https://taymoorfouladi.pages.dev';
    const shareData = {
      title: 'Taymoor Fouladi',
      text: 'Taymoor Fouladi — Director / AI Transformation / Digital Product / CX',
      url,
    };
    try {
      if ((navigator as any).share) {
        await (navigator as any).share(shareData);
      } else {
        await navigator.clipboard.writeText(url);
        if (shareLabel) {
          shareLabel.textContent = 'Copied!';
          setTimeout(() => { if (shareLabel) shareLabel.textContent = 'Share link'; }, 1800);
        }
      }
    } catch {}
  });
</script>

<style>
  .bc-wrapper {
    --bc-cream: #FAF7F2;
    --bc-ink: #1A1A1A;
    --bc-coral: #FF6B47;
    --bc-mute: #888;
    --bc-line: rgba(26,26,26,0.1);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    perspective: 1500px;
    width: 100%;
  }

  .bc-card {
    position: relative;
    width: min(520px, 100%);
    aspect-ratio: 1.75 / 1;
    transform-style: preserve-3d;
    -webkit-transform-style: preserve-3d;
    transition: transform 0.85s cubic-bezier(0.6, -0.05, 0.3, 1.2);
    cursor: pointer;
    user-select: none;
    will-change: transform;
  }

  .bc-card.is-flipped { transform: rotateY(180deg); }

  .bc-card:focus-visible {
    outline: 3px solid var(--bc-coral);
    outline-offset: 4px;
    border-radius: 16px;
  }

  .bc-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    background: var(--bc-cream);
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.04),
      0 10px 30px -10px rgba(0,0,0,0.25),
      0 20px 60px -30px rgba(0,0,0,0.15);
    color: var(--bc-ink);
    container-type: inline-size;
  }

  .bc-front { transform: rotateY(0deg); }
  .bc-back { transform: rotateY(180deg); }

  /* FRONT --------------------------------------- */
  .bc-front { padding: clamp(20px, 5%, 32px); }

  .bc-content { position: relative; z-index: 2; max-width: 65%; }

  .bc-eyebrow {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: clamp(9px, 1.6cqw, 11px);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--bc-coral);
    margin: 0 0 0.75rem;
    font-weight: 600;
  }

  .bc-name {
    font-family: 'Fraunces', 'Playfair Display', Georgia, serif;
    font-weight: 600;
    font-size: clamp(28px, 7.5cqw, 56px);
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 0 0 1rem;
    display: flex;
    flex-direction: column;
  }

  .bc-role {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: clamp(10px, 1.7cqw, 12px);
    line-height: 1.5;
    color: var(--bc-mute);
    margin: 0 0 1rem;
  }

  .bc-loc {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: clamp(9px, 1.5cqw, 11px);
    color: var(--bc-ink);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  /* DECOR --------------------------------------- */
  .bc-decor {
    position: absolute;
    right: -10%;
    top: -20%;
    bottom: -20%;
    width: 55%;
    z-index: 1;
    pointer-events: none;
  }

  .bc-circle {
    position: absolute;
    right: -5%;
    top: 10%;
    width: 80%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--bc-coral);
  }

  .bc-ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid var(--bc-coral);
    opacity: 0.55;
  }
  .bc-ring-1 {
    right: 30%;
    bottom: -5%;
    width: 45%;
    aspect-ratio: 1;
  }
  .bc-ring-2 {
    right: 60%;
    top: 50%;
    width: 25%;
    aspect-ratio: 1;
    opacity: 0.4;
  }
  .bc-dot {
    position: absolute;
    right: 20%;
    top: 5%;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--bc-ink);
  }

  /* BACK --------------------------------------- */
  .bc-back-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(16px, 4%, 28px);
    align-items: center;
    padding: clamp(20px, 5%, 32px);
    height: 100%;
  }

  .bc-qr-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .bc-qr {
    width: clamp(110px, 28cqw, 160px);
    height: clamp(110px, 28cqw, 160px);
    aspect-ratio: 1;
    background: #fff;
    border-radius: 12px;
    padding: 10px;
    box-shadow: 0 4px 10px rgba(0,0,0,0.06);
    flex-shrink: 0;
  }
  .bc-qr :global(svg) {
    width: 100% !important;
    height: 100% !important;
    display: block;
  }

  .bc-qr-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 10px;
    color: var(--bc-mute);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .bc-back-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    min-width: 0;
  }

  .bc-links {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .bc-links li {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 8px;
    align-items: baseline;
    font-family: 'Inter', sans-serif;
    font-size: clamp(10px, 1.7cqw, 12px);
    line-height: 1.3;
  }
  .bc-link-label {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 9px;
    color: var(--bc-mute);
  }
  .bc-link-val {
    color: var(--bc-ink);
    font-weight: 500;
    overflow-wrap: anywhere;
  }

  .bc-back-meta {
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: clamp(9px, 1.4cqw, 10px);
    color: var(--bc-mute);
    margin: 0.5rem 0 0;
    line-height: 1.5;
    border-top: 1px solid var(--bc-line);
    padding-top: 0.5rem;
  }

  /* HINT --------------------------------------- */
  .bc-flip-hint {
    position: absolute;
    bottom: 10px;
    right: 14px;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
    font-size: 9px;
    color: var(--bc-mute);
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
    z-index: 3;
  }
  .bc-card:hover .bc-flip-hint { opacity: 0.7; }

  /* ACTIONS ------------------------------------ */
  .bc-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }

  .bc-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    border: 1px solid transparent;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .bc-btn:hover { transform: translateY(-1px); opacity: 0.9; }
  .bc-btn:active { transform: translateY(0); }

  .bc-btn-primary {
    background: var(--accent);
    color: #fff;
    text-decoration: none;
  }
  .bc-btn-ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--line);
  }

  @media (prefers-reduced-motion: reduce) {
    .bc-card { transition: none; }
  }
</style>
