---
interface Props {
  href: string;
  title: string;
  hero?: string;
  summary?: string;
}
const { href, title, hero, summary } = Astro.props;
---

<a href={href} class="group block rounded-2xl overflow-hidden border transition-all hover:-translate-y-1 hover:shadow-xl" style="border-color: var(--line);">
  <div class="aspect-[4/3] overflow-hidden bg-ink-100 dark:bg-ink-800 flex items-center justify-center p-8">
    {hero ? (
      <img src={hero} alt={title} class="w-full h-full object-contain transition-transform group-hover:scale-105" loading="lazy" />
    ) : (
      <span class="font-display text-4xl opacity-30">{title}</span>
    )}
  </div>
  <div class="p-5">
    <h3 class="font-display text-xl font-semibold tracking-tight group-hover:text-accent transition-colors" style="color: var(--fg);">
      {title}
    </h3>
    {summary && <p class="mt-2 text-sm line-clamp-2" style="color: var(--muted)">{summary}</p>}
    <p class="mt-3 text-xs font-mono uppercase tracking-wider opacity-50">Read case study →</p>
  </div>
</a>
