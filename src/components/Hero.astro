---
interface Props {
  title: string;
  tagline?: string;
  intro?: string;
  image?: string;
}
const { title, tagline, intro, image } = Astro.props;
---

<section class="bg-grid">
  <div class="max-w-7xl mx-auto px-4 md:px-8 pt-16 pb-20 md:pt-28 md:pb-32 grid md:grid-cols-12 gap-10 items-center">
    <div class="md:col-span-7">
      {tagline && <p class="font-mono text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--accent)">{tagline}</p>}
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-semibold leading-[0.95] tracking-tight">
        {title}
      </h1>
      {intro && <p class="mt-6 text-lg md:text-xl max-w-prose" style="color: var(--muted)">{intro}</p>}
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/portfolio" class="px-6 py-3 rounded-full font-semibold text-white" style="background: var(--accent)">
          View Portfolio →
        </a>
        <a href="/career" class="px-6 py-3 rounded-full font-semibold border" style="border-color: var(--line);">
          See Career
        </a>
      </div>
    </div>
    {image && (
      <div class="md:col-span-5">
        <div class="aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
          <img src={image} alt="Taymoor Fouladi" class="w-full h-full object-cover" />
        </div>
      </div>
    )}
  </div>
</section>
