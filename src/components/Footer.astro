---
const year = new Date().getFullYear();
---

<footer class="border-t mt-24" style="border-color: var(--line);">
  <div class="max-w-7xl mx-auto px-4 md:px-8 py-12 grid gap-8 md:grid-cols-3">
    <div>
      <a href="/" class="font-display font-bold text-2xl">Taymoor<span style="color: var(--accent)">.</span></a>
      <p class="mt-3 text-sm" style="color: var(--muted)">
        Director / Product / CX UX UI / AI<br/>
        Currently in Tokyo · Previously London, Munich, Amsterdam
      </p>
    </div>
    <div>
      <h4 class="font-semibold text-sm uppercase tracking-wider mb-3" style="color: var(--muted)">Explore</h4>
      <ul class="space-y-2 text-sm">
        <li><a href="/portfolio" class="hover:opacity-70">Portfolio</a></li>
        <li><a href="/career" class="hover:opacity-70">Career</a></li>
        <li><a href="/blog" class="hover:opacity-70">Blog</a></li>
        <li><a href="/about" class="hover:opacity-70">About</a></li>
        <li><a href="/contact" class="hover:opacity-70">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-semibold text-sm uppercase tracking-wider mb-3" style="color: var(--muted)">Get in touch</h4>
      <p class="text-sm">
        <a href="mailto:taymoor13@icloud.com" class="hover:opacity-70">taymoor13@icloud.com</a>
      </p>
      <p class="text-sm mt-2" style="color: var(--muted)">
        Open to opportunities and collaborations.
      </p>
    </div>
  </div>
  <div class="border-t" style="border-color: var(--line);">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-4 text-xs flex items-center justify-between" style="color: var(--muted)">
      <span>© {year} Taymoor Fouladi. All rights reserved.</span>
      <span>Built with Astro.</span>
    </div>
  </div>
</footer>
