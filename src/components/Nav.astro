---
const items = [
  { href: '/', label: 'Home' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/career', label: 'Career' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const path = Astro.url.pathname;
function isActive(href) {
  if (href === '/') return path === '/';
  return path.startsWith(href);
}
---

<header class="sticky top-0 z-50 backdrop-blur border-b" style="background: color-mix(in srgb, var(--bg) 85%, transparent); border-color: var(--line);">
  <div class="max-w-7xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
    <a href="/" class="font-display font-bold text-lg tracking-tight">
      Taymoor<span style="color: var(--accent)">.</span>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {items.map(item => (
        <a
          href={item.href}
          class:list={[
            "px-3 py-2 rounded-md text-sm font-medium transition-colors",
            isActive(item.href) ? "text-white" : "hover:bg-ink-100 dark:hover:bg-ink-800"
          ]}
          style={isActive(item.href) ? "background: var(--accent); color: white;" : ""}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="flex items-center gap-2">
      <a href="/cv.pdf" class="hidden sm:inline-flex px-3 py-1.5 rounded-md text-xs font-semibold border" style="border-color: var(--line);">
        DOWNLOAD CV
      </a>
      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="p-2 rounded-md text-sm hover:opacity-70"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
      </button>
      <button id="menu-toggle" class="md:hidden p-2 rounded-md" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>
  <nav id="mobile-menu" class="md:hidden hidden border-t" style="border-color: var(--line);">
    <div class="px-4 py-4 space-y-1">
      {items.map(item => (
        <a href={item.href} class="block px-3 py-2 rounded-md text-base font-medium hover:bg-ink-100 dark:hover:bg-ink-800">
          {item.label}
        </a>
      ))}
    </div>
  </nav>
</header>

<script>
  const tt = document.getElementById('theme-toggle');
  tt?.addEventListener('click', () => {
    const dark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', dark ? 'dark' : 'light');
  });
  const mt = document.getElementById('menu-toggle');
  const mm = document.getElementById('mobile-menu');
  mt?.addEventListener('click', () => mm?.classList.toggle('hidden'));
</script>
