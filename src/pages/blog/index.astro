---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Blog" description="Thoughts on customer experience, product, design, and leadership.">
  <section class="max-w-5xl mx-auto px-4 md:px-8 py-16 md:py-24">
    <p class="font-mono text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--accent)">Journal</p>
    <h1 class="font-display text-5xl md:text-7xl font-semibold tracking-tight leading-[0.95]">
      SilverSurfer13 Blog
    </h1>
    <p class="mt-6 text-lg md:text-xl max-w-2xl" style="color: var(--muted)">
      Notes on customer experience, product, leadership — and the occasional sneaker drop.
    </p>

    <div class="mt-16 grid md:grid-cols-2 gap-8">
      {posts.map(p => (
        <a href={`/blog/${p.slug}`} class="group block">
          {p.data.hero && (
            <div class="aspect-[16/10] rounded-2xl overflow-hidden bg-ink-100 dark:bg-ink-800 mb-5">
              <img src={p.data.hero} alt={p.data.title} class="w-full h-full object-cover transition-transform group-hover:scale-105" loading="lazy" />
            </div>
          )}
          {p.data.date && (
            <p class="font-mono text-xs uppercase tracking-wider" style="color: var(--muted)">{p.data.date}</p>
          )}
          <h2 class="mt-2 font-display text-2xl md:text-3xl font-semibold tracking-tight group-hover:text-accent transition-colors">
            {p.data.title}
          </h2>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
