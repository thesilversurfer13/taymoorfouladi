---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RoleCard from '../../components/RoleCard.astro';
import { getCollection } from 'astro:content';

const roles = (await getCollection('career')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Career" description="15+ years of digital experience leadership across adidas, Rakuten, Esprit, Harrods, Net-A-Porter and more.">
  <section class="max-w-5xl mx-auto px-4 md:px-8 py-16 md:py-24">
    <p class="font-mono text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--accent)">Career</p>
    <h1 class="font-display text-5xl md:text-7xl font-semibold tracking-tight leading-[0.95]">
      Where I've Built
    </h1>
    <p class="mt-6 text-lg md:text-xl max-w-2xl" style="color: var(--muted)">
      A timeline of roles spanning London, Munich, Amsterdam, and Tokyo. Senior leadership in product, experience design, and digital strategy.
    </p>

    <div class="mt-16 space-y-3">
      {roles.map(r => (
        <RoleCard
          href={`/career/${r.slug}`}
          title={r.data.title}
          hero={r.data.hero}
          summary={r.data.summary}
        />
      ))}
    </div>
  </section>
</BaseLayout>
