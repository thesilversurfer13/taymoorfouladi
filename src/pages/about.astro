---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const about = await getEntry('pages', 'about');
const { Content } = await about.render();
---

<BaseLayout title="About" description={about.data.description} image={about.data.hero}>
  <article class="max-w-4xl mx-auto px-4 md:px-8 py-16 md:py-24">
    <p class="font-mono text-xs uppercase tracking-[0.2em] mb-4" style="color: var(--accent)">About</p>
    <h1 class="font-display text-4xl md:text-6xl font-semibold tracking-tight leading-tight">
      Senior digital and product leader, building human-centred experiences and enterprise AI at global scale.
    </h1>
    <p class="mt-6 text-lg md:text-xl max-w-prose" style="color: var(--muted)">
      20+ years across Rakuten, adidas, Esprit, Harrods, Net-a-Porter and Value Retail —
      bridging product, UX, engineering and AI transformation.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a href="/cv.pdf" target="_blank" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-semibold text-white text-sm" style="background: var(--accent)">
        Download CV →
      </a>
      <a href="/contact" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full font-semibold text-sm border" style="border-color: var(--line)">
        Get in touch
      </a>
    </div>

    {about.data.hero && (
      <div class="mt-12 rounded-2xl overflow-hidden">
        <img src={about.data.hero} alt="Taymoor Fouladi" class="w-full" />
      </div>
    )}

    <div class="prose-custom mt-16">
      <Content />
    </div>
  </article>
</BaseLayout>
